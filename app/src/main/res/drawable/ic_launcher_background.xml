<?xml version="1.0" encoding="utf-8"?>
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:aapt="http://schemas.android.com/aapt"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">
    <!-- Rich diagonal gradient from deep indigo to teal-blue so the
         keyboard glyph pops without competing with the system's adaptive
         icon mask. -->
    <path android:pathData="M0,0 L108,0 L108,108 L0,108 Z">
        <aapt:attr name="android:fillColor">
            <gradient
                android:startX="0" android:startY="0"
                android:endX="108" android:endY="108"
                android:type="linear"
                android:startColor="#321F73"
                android:centerColor="#2546B8"
                android:endColor="#0F6FE6" />
        </aapt:attr>
    </path>
    <!-- Soft top-left highlight to fake a glossy curve. -->
    <path android:pathData="M0,0 L108,0 L108,18 C 70,42 30,42 0,18 Z"
        android:fillColor="#22FFFFFF" />
</vector>
